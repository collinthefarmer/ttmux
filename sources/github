#!/usr/bin/env bash
# github — search repositories via GitHub API (no auth, 10 req/min limit)
# outputs: title\turl\tsnippet
set -euo pipefail

query="${1:?usage: github <query>}"
encoded=$(printf '%s' "$query" | jq -sRr @uri)

curl -sL --max-time 10 \
    "https://api.github.com/search/repositories?q=${encoded}&per_page=10" \
    -H "Accept: application/vnd.github.v3+json" \
    2>/dev/null \
| jq -r '.items[]? | [.full_name, .html_url, (.description // "no description" | .[0:200])] | @tsv'
