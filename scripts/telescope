#!/usr/bin/env bash
#
# telescope — search across multiple sources, preview results, browse interactively
#
# Sources are executable scripts in the sources directory. Each receives
# a query as $1 and outputs tab-delimited results to stdout:
#
#   title\turl\tsnippet
#
# One result per line. Exit 0 on success, even if no results.
# The script filename is used as the source name in the UI.
#
# Source directories (checked in order, first found wins):
#   ~/.config/ttmux/telescope/sources/
#   <ttmux-dir>/sources/
#
# Usage:
#   telescope              Launch the fzf interface (via fzf-dispatch)
#   telescope --resolve Q  Resolve query Q against all sources, output results

set -euo pipefail

# bootstrap: if deps aren't on PATH, re-exec under nix shell
if ! command -v jq >/dev/null 2>&1 || ! command -v fzf >/dev/null 2>&1; then
    exec nix --extra-experimental-features 'nix-command flakes' shell \
        nixpkgs#curl nixpkgs#jq nixpkgs#fzf \
        nixpkgs#w3m nixpkgs#xmlstarlet nixpkgs#coreutils \
        --command bash "$0" "$@"
fi

SELF=$(realpath "$0")
TTMUX_DIR=$(dirname "$SELF")/..
USER_SOURCES="${XDG_CONFIG_HOME:-$HOME/.config}/ttmux/telescope/sources"
DEFAULT_SOURCES="$TTMUX_DIR/sources"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/ttmux/telescope"
mkdir -p "$CACHE_DIR"

# --- gather: run all sources for a query -----------------------------------

gather() {
    local query="$1"
    [[ -z "$query" ]] && return 0

    local sources_dir="$DEFAULT_SOURCES"
    [[ -d "$USER_SOURCES" ]] && sources_dir="$USER_SOURCES"

    [[ -d "$sources_dir" ]] || return 0

    for src in "$sources_dir"/*; do
        [[ -x "$src" ]] || continue
        local name
        name=$(basename "$src")

        # run source, prepend source name to each result line
        "$src" "$query" 2>/dev/null \
            | while IFS= read -r line; do
                [[ -n "$line" ]] && printf '%s\t%s\n' "$name" "$line"
            done &
    done
    wait
}

# --- rank: score results by query relevance --------------------------------

rank() {
    local query="$1"
    awk -F'\t' -v query="$query" '
    BEGIN {
        q = tolower(query)
        n = split(q, words, /[[:space:]]+/)
    }
    {
        title = tolower($2)
        snippet = tolower($4)
        score = 0

        # bonus for full query in title
        if (index(title, q) > 0) score += 20

        # per-word matches
        for (i = 1; i <= n; i++) {
            if (index(title, words[i]) > 0) score += 10
            if (index(snippet, words[i]) > 0) score += 3
        }

        printf "%d\t%s\n", score, $0
    }' | sort -t$'\t' -k1 -rn | cut -f2-
}

# --- resolve: gather + rank ------------------------------------------------

resolve() {
    local query="$1"
    gather "$query" | rank "$query"
}

# --- main ------------------------------------------------------------------

if [[ "${1:-}" == "--resolve" ]]; then
    shift
    resolve "$*"
    exit 0
fi

# register search popup close key (T toggles telescope closed)
POPUP_KEYS="$(dirname "$SELF")/popup-keys"
"$POPUP_KEYS" bind search T detach-client

# set up tmux options for fzf-dispatch
PREVIEW_CMD="$(dirname "$SELF")/telescope-preview"
tmux set-option @telescopeFzf \
    "--border --border-label=\" telescope \" --delimiter=$'\t' --with-nth=1,2 --ellipsis=… --no-hscroll --preview=\"$PREVIEW_CMD {}\" --preview-window=right:60%:wrap --header=\"type to search, enter=open\""
OPEN_CMD="$(dirname "$SELF")/telescope-open"
tmux set-option @telescopeOpen "$OPEN_CMD '{}'"

exec "$(dirname "$SELF")/fzf-dispatch" \
    "" telescopeFzf telescopeOpen \
    --reload "$SELF --resolve {q}" \
    --field 3
