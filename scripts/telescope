#!/usr/bin/env bash
#
# telescope — search across multiple sources, preview results, browse interactively
#
# Modes:
#   telescope              Launch the fzf interface (default)
#   telescope --resolve Q  Resolve query Q against all sources, output results
#
# Sources are configurable via ~/.config/ttmux/telescope.conf
# (one per line, pipe-delimited):
#
#   name|type|target
#
# Types:
#   surfraw  — target is a surfraw elvis name
#   rss      — target is a base RSS URL (query appended as ?q= or &q=)

set -euo pipefail

# bootstrap: if surfraw is not on PATH, re-exec under nix shell with all deps
if ! command -v surfraw >/dev/null 2>&1; then
    exec nix --extra-experimental-features 'nix-command flakes' shell \
        nixpkgs#surfraw nixpkgs#w3m nixpkgs#jq \
        nixpkgs#xmlstarlet nixpkgs#curl nixpkgs#fzf \
        --command bash "$0" "$@"
fi

# surfraw needs its config dir to find elvi
if [[ -z "${XDG_CONFIG_DIRS:-}" ]]; then
    surfraw_prefix=$(dirname "$(dirname "$(command -v surfraw)")")
    export XDG_CONFIG_DIRS="$surfraw_prefix/etc/xdg"
elif [[ "$XDG_CONFIG_DIRS" != *surfraw* ]]; then
    surfraw_prefix=$(dirname "$(dirname "$(command -v surfraw)")")
    export XDG_CONFIG_DIRS="$XDG_CONFIG_DIRS:$surfraw_prefix/etc/xdg"
fi

CONF="${XDG_CONFIG_HOME:-$HOME/.config}/ttmux/telescope.conf"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/ttmux/telescope"
mkdir -p "$CACHE_DIR"

# --- sources ---------------------------------------------------------------
# Each source has a static relevance weight (higher = shown first).
# Weights are assigned by list position: first source = highest.

DEFAULT_SOURCES=(
    "duckduckgo|surfraw|duckduckgo"
    "wikipedia|surfraw|wikipedia"
    "github|surfraw|github"
    "stack overflow|surfraw|stack"
    "arxiv|surfraw|arxiv"
    "scholar|surfraw|scholar"
)

load_sources() {
    if [[ -f "$CONF" ]]; then
        SOURCES=()
        while IFS= read -r line; do
            [[ -z "$line" || "$line" == \#* ]] && continue
            SOURCES+=("$line")
        done < "$CONF"
    else
        SOURCES=("${DEFAULT_SOURCES[@]}")
    fi
}

# --- resolve: generate source results for a query -------------------------

resolve() {
    local query="$1"
    [[ -z "$query" ]] && return 0

    load_sources

    local total=${#SOURCES[@]}
    local i=0
    for src in "${SOURCES[@]}"; do
        IFS='|' read -r name type target <<< "$src"
        local url=""
        case "$type" in
            surfraw)
                url=$(surfraw -print "$target" "$query" 2>/dev/null) || url=""
                ;;
            rss)
                local encoded
                encoded=$(printf '%s' "$query" | jq -sRr @uri)
                if [[ "$target" == *"?"* ]]; then
                    url="${target}&q=${encoded}"
                else
                    url="${target}?q=${encoded}"
                fi
                ;;
        esac
        if [[ -n "$url" ]]; then
            # relevance: position-based weight (first source = highest score)
            # TODO: replace with actual relevance scoring (response status, result count, etc.)
            local score=$(( total - i ))
            printf '%s\t%s\t%s\t%s\n' "$score" "$name" "$type" "$url"
        fi
        (( i++ )) || true
    done | sort -t$'\t' -k1 -rn
}

# --- preview script (passed to fzf) ---------------------------------------

read -r -d '' PREVIEW_SCRIPT << 'PREVIEW_EOF' || true
line="{}"
type=$(printf '%s' "$line" | cut -f3)
url=$(printf '%s' "$line" | cut -f4)

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/ttmux/telescope"
key=$(printf '%s' "$url" | cksum | cut -d' ' -f1)
cache="$CACHE_DIR/preview.${key}"

if [[ -f "$cache" ]]; then
    cat "$cache"
    exit 0
fi

if [[ "$type" == "rss" ]]; then
    result=$(curl -sL --max-time 10 "$url" 2>/dev/null)
    if command -v xmlstarlet >/dev/null 2>&1; then
        echo "$result" \
            | xmlstarlet sel -t -m '//item' \
                -v 'title' -n -v 'link' -n -n \
                2>/dev/null \
            | head -100 \
            | tee "$cache"
    else
        echo "$result" \
            | w3m -dump -T text/xml 2>/dev/null \
            | head -100 \
            | tee "$cache"
    fi
else
    timeout 15 curl -sL --max-time 10 "$url" 2>/dev/null \
        | w3m -dump -T text/html -cols "${FZF_PREVIEW_COLUMNS:-80}" 2>/dev/null \
        | head -200 \
        | tee "$cache"
fi
PREVIEW_EOF

# --- main: launch fzf or resolve ------------------------------------------

if [[ "${1:-}" == "--resolve" ]]; then
    shift
    resolve "$*"
    exit 0
fi

SELF=$(realpath "$0")

SELECTED=$(
    fzf \
        --tmux 90%,80% \
        --disabled \
        --border \
        --border-label=" telescope " \
        --delimiter=$'\t' \
        --with-nth=2 \
        --preview="$PREVIEW_SCRIPT" \
        --preview-window=right:70%:wrap \
        --header="type to search, enter=browse" \
        --bind "change:reload:$SELF --resolve {q} || true" \
        < /dev/null
) || exit 0

# --- output selected URL --------------------------------------------------

URL=$(printf '%s' "$SELECTED" | cut -f4)
[[ -n "$URL" ]] && echo "$URL"
