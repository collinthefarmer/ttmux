#!/usr/bin/env bash
#
# fidget-test — probe tmux popup animation behavior
#
# Tests three approaches to animation inside a display-popup:
#   1. Cursor-addressed redraws (tput / ANSI escapes)
#   2. Rapid size/position changes via the outer tmux
#   3. Unicode braille-dot spinner
#
# Usage:
#   fidget-test [bounce|resize|spinner]
#   (default: bounce)

set -euo pipefail

FRAME_MS=50  # milliseconds per frame

sleep_ms() { sleep "$(awk "BEGIN{printf \"%.3f\", $1/1000}")"; }

# ── bounce ──────────────────────────────────────────────────────
# A ball careening around inside the popup. Cursor-addressed
# redraws — tests whether the popup repaints smoothly.
bounce() {
    local cols lines
    cols=$(tput cols)
    lines=$(tput lines)

    local x=1 y=1 dx=1 dy=1
    local ball="●"
    local trail="·"

    tput civis          # hide cursor
    tput clear
    trap 'tput cnorm; tput clear' EXIT

    local prev_x=$x prev_y=$y
    while true; do
        # erase previous position
        tput cup "$prev_y" "$prev_x"
        printf "\033[2m%s\033[0m" "$trail"

        # move
        (( x += dx )) || true
        (( y += dy )) || true

        # wall collisions
        if (( x <= 0 || x >= cols - 1 )); then
            (( dx = -dx )) || true
            (( x += dx )) || true
        fi
        if (( y <= 0 || y >= lines - 1 )); then
            (( dy = -dy )) || true
            (( y += dy )) || true
        fi

        # draw ball
        tput cup "$y" "$x"
        printf "\033[1;33m%s\033[0m" "$ball"

        prev_x=$x prev_y=$y
        sleep_ms "$FRAME_MS"
    done
}

# ── resize ──────────────────────────────────────────────────────
# Pulse the popup by closing and reopening at new sizes. There is
# no resize-popup command — this is the only way to change geometry.
# Tests how much flicker the close/reopen cycle produces.
resize_outer() {
    local min_w=10 max_w=50 min_h=5 max_h=20
    local w=$min_w h=$min_h grow_w=1 grow_h=1

    for _ in $(seq 1 80); do
        (( w += grow_w * 2 )) || true
        (( h += grow_h )) || true

        if (( w >= max_w )); then grow_w=-1; fi
        if (( w <= min_w )); then grow_w=1;  fi
        if (( h >= max_h )); then grow_h=-1; fi
        if (( h <= min_h )); then grow_h=1;  fi

        # -E with a short sleep holds the popup for one frame
        tmux display-popup -w "$w" -h "$h" -E "sleep 0.016" 2>/dev/null
    done
}

# ── spinner ─────────────────────────────────────────────────────
# Braille-dot spinner with a cycling color ramp. Minimal — tests
# raw repaint speed in small popups.
spinner() {
    local frames=( "⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏" )
    local colors=( 196 202 208 214 220 226 190 154 118 82 46 47 48 49 50 51 )
    local nf=${#frames[@]} nc=${#colors[@]}
    local i=0

    tput civis
    trap 'tput cnorm' EXIT

    while true; do
        local f=${frames[i % nf]}
        local c=${colors[i % nc]}
        tput cup 1 2
        printf "\033[38;5;%sm %s \033[0m" "$c" "$f"
        tput cup 3 2
        printf "\033[2m%3d\033[0m" "$((i % 360))"
        (( i++ )) || true
        sleep_ms 60
    done
}

# ── main ────────────────────────────────────────────────────────
mode="${1:-bounce}"
case "$mode" in
    bounce)
        # open inside a popup so we can read its geometry
        if [[ -z "${TMUX_PANE:-}" ]] || [[ "${FIDGET_INSIDE:-}" == "1" ]]; then
            FIDGET_INSIDE=1 bounce
        else
            tmux display-popup -w 40 -h 16 -E "FIDGET_INSIDE=1 '$0' bounce"
        fi
        ;;
    resize)
        resize_outer
        ;;
    spinner)
        if [[ -z "${TMUX_PANE:-}" ]] || [[ "${FIDGET_INSIDE:-}" == "1" ]]; then
            FIDGET_INSIDE=1 spinner
        else
            tmux display-popup -w 8 -h 6 -E "FIDGET_INSIDE=1 '$0' spinner"
        fi
        ;;
    *)
        echo "usage: fidget-test [bounce|resize|spinner]" >&2
        exit 1
        ;;
esac
