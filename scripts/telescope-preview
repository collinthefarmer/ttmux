#!/usr/bin/env bash
#
# telescope-preview — render a telescope result for fzf preview pane
#
# Receives a tab-delimited line as $1:
#   source\ttitle\turl\tsnippet

set -euo pipefail

line="$1"
source_name=$(printf '%s' "$line" | cut -f1)
title=$(printf '%s' "$line" | cut -f2)
url=$(printf '%s' "$line" | cut -f3)
snippet=$(printf '%s' "$line" | cut -f4)

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/ttmux/telescope"

if [[ -n "$snippet" ]]; then
    cols="${FZF_PREVIEW_COLUMNS:-60}"
    printf '\033[1m%s\033[0m\n' "$title"
    printf '\033[2m%s · %s\033[0m\n\n' "$source_name" "$url"

    # clean up the snippet for terminal display:
    #   - break on ellipsis markers (section boundaries)
    #   - collapse whitespace runs (flattened code blocks)
    #   - word-wrap to preview width
    printf '%s\n' "$snippet" \
        | sed 's/ … /\n\n/g; s/…/\n\n/g' \
        | sed 's/  \+/ /g' \
        | fold -s -w "$cols"
    exit 0
fi

# fall back to fetching the URL
key=$(printf '%s' "$url" | cksum | cut -d' ' -f1)
cache="$CACHE_DIR/preview.${key}"

if [[ -f "$cache" ]]; then
    cat "$cache"
    exit 0
fi

if command -v w3m >/dev/null 2>&1; then
    timeout 15 curl -sL --max-time 10 "$url" 2>/dev/null \
        | w3m -dump -T text/html -cols "${FZF_PREVIEW_COLUMNS:-80}" 2>/dev/null \
        | head -200 \
        | tee "$cache"
else
    printf '%s\n' "$url"
fi
