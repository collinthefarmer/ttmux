#!/usr/bin/env bash
#
# fidget-recipes — cycle through popup-open animation combos
#
# Each recipe opens a small popup, holds it briefly, then moves
# to the next. Press q or C-c inside any popup to stop early.

set -euo pipefail

dir="$(dirname "$0")"
open="$dir/popup-open"
hold='read -rsn1 -t 1.5 || true'

recipes=(
    "rise from bottom"
    "--origin bottom --scale none --duration 300 --fps 20 -- -b rounded -w 60% -h 60%"

    "rise from bottom + grow"
    "--origin bottom --scale uniform --easing ease-out --duration 350 --fps 20 -- -b rounded -w 60% -h 60%"

    "drop from top (ease-in)"
    "--origin top --scale none --easing ease-in --duration 300 --fps 20 -- -b rounded -w 50% -h 40%"

    "slide from right"
    "--origin right --scale none --easing ease-out --duration 300 --fps 20 -- -b rounded -w 40% -h 50%"

    "slide from left + grow"
    "--origin left --scale width-first --easing ease-in-out --duration 400 --fps 15 -- -b rounded -w 70% -h 60%"

    "center scale (ease-out)"
    "--scale uniform --easing ease-out --duration 300 --fps 20 -- -b rounded -w 70% -h 60%"

    "center scale (ease-in)"
    "--scale uniform --easing ease-in --duration 300 --fps 20 -- -b rounded -w 70% -h 60%"

    "center scale (ease-in-out)"
    "--scale uniform --easing ease-in-out --duration 350 --fps 15 -- -b rounded -w 70% -h 60%"

    "width-first unfurl"
    "--scale width-first --easing ease-out --duration 400 --fps 15 -- -b rounded -w 80% -h 60%"

    "height-first unfurl"
    "--scale height-first --easing ease-out --duration 400 --fps 15 -- -b rounded -w 60% -h 70%"

    "slow rise"
    "--origin bottom --scale uniform --easing ease-in-out --duration 600 --fps 15 -- -b rounded -w 70% -h 70%"

    "fast snap"
    "--origin bottom --scale none --easing linear --duration 150 --fps 20 -- -b rounded -w 50% -h 40%"
)

total=$(( ${#recipes[@]} / 2 ))
i=0

while (( i < ${#recipes[@]} )); do
    name="${recipes[i]}"
    args="${recipes[i+1]}"
    num=$(( i / 2 + 1 ))
    (( i += 2 ))

    echo -e "\033[1;36m[$num/$total]\033[0m $name"

    # shellcheck disable=SC2086
    "$open" $args -E "$hold"

    sleep 0.3
done

echo -e "\033[1;32mdone\033[0m"
