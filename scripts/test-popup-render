#!/usr/bin/env bash
#
# test-popup-render — tests for tmux popup rendering behavior
#
# Opens real tmux popups and inspects their internal state to verify
# dimensions, styling, and fill behavior. Requires a running tmux
# session (will refuse to run outside tmux).
#
# All popup sizes are derived from the actual window dimensions so
# tests work on any terminal size.
#
# Usage:
#   test-popup-render [--verbose]

set -euo pipefail

if [[ -z "${TMUX:-}" ]]; then
    echo "test-popup-render: must run inside tmux" >&2
    exit 1
fi

verbose=0
[[ "${1:-}" == "--verbose" ]] && verbose=1

pass=0
fail=0
total=0

# ── test harness ───────────────────────────────────────────────

assert_eq() {
    local label="$1" expected="$2" actual="$3"
    (( total++ )) || true
    if [[ "$expected" == "$actual" ]]; then
        (( pass++ )) || true
        (( verbose )) && printf "  \033[32mpass\033[0m  %s\n" "$label" || true
    else
        (( fail++ )) || true
        printf "  \033[31mFAIL\033[0m  %s: expected '%s', got '%s'\n" \
            "$label" "$expected" "$actual"
    fi
}

section() {
    printf "\n\033[1m── %s ──\033[0m\n" "$1"
}

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"; tmux kill-session -t _tpr 2>/dev/null || true' EXIT

# source geometry library for animation math
# shellcheck source=popup-geometry
source "$(dirname "$0")/popup-geometry"

# ── window dimensions ─────────────────────────────────────────
win_w=$(tmux display-message -p '#{window_width}')
win_h=$(tmux display-message -p '#{window_height}')

# derive test sizes from actual window (leave margin for borders)
small_w=$(( win_w * 30 / 100 ))
small_h=$(( win_h * 30 / 100 ))
med_w=$(( win_w * 50 / 100 ))
med_h=$(( win_h * 50 / 100 ))
large_w=$(( win_w * 80 / 100 ))
large_h=$(( win_h * 80 / 100 ))

if (( small_w < 6 || small_h < 4 )); then
    echo "test-popup-render: terminal too small (${win_w}x${win_h})" >&2
    exit 1
fi

# ── helpers ────────────────────────────────────────────────────

# popup_tty_size POPUP_ARGS...
# Opens a standalone popup and queries PTY dimensions via stty.
# Prints "WIDTHxHEIGHT".
popup_tty_size() {
    local out="$tmpdir/tty.$$.$RANDOM"
    tmux display-popup "$@" \
        -E "stty size > '$out'" 2>/dev/null
    if [[ -f "$out" ]]; then
        local rows cols
        read -r rows cols < "$out"
        rm -f "$out"
        echo "${cols}x${rows}"
    else
        echo ""
    fi
}

# popup_session_open [-w W] [-h H] [-b border] [-s style] [other popup args]
POPUP_PID=""
popup_session_open() {
    local sess="_tpr"
    tmux kill-session -t "$sess" 2>/dev/null || true
    tmux new-session -d -s "$sess"

    tmux display-popup "$@" \
        -E "tmux attach -t '$sess'" &
    POPUP_PID=$!
    sleep 0.3
}

popup_session_query() {
    tmux display-message -t "_tpr" -p "$1" 2>/dev/null || echo ""
}

popup_session_capture() {
    local setup_cmd="${1:-}"
    if [[ -n "$setup_cmd" ]]; then
        tmux send-keys -t "_tpr" "$setup_cmd" Enter
        sleep 0.1
    fi
    tmux capture-pane -t "_tpr" -e -p 2>/dev/null
}

popup_session_close() {
    tmux kill-session -t "_tpr" 2>/dev/null || true
    if [[ -n "$POPUP_PID" ]]; then
        wait "$POPUP_PID" 2>/dev/null || true
        POPUP_PID=""
    fi
}

# hex_to_rgb HEX — convert #rrggbb to R;G;B
hex_to_rgb() {
    local hex="${1#\#}"
    printf "%d;%d;%d" \
        "$(printf "%d" "0x${hex:0:2}")" \
        "$(printf "%d" "0x${hex:2:2}")" \
        "$(printf "%d" "0x${hex:4:2}")"
}

# popup_fill_open -w W -h H [-x X] [-y Y] COLOR_RGB
# Opens a popup with a session running a raw fill command.
popup_fill_open() {
    local popup_args=()
    while [[ $# -gt 1 ]]; do
        popup_args+=("$1"); shift
    done
    local rgb="$1"

    local sess="_tpr"
    tmux kill-session -t "$sess" 2>/dev/null || true
    tmux new-session -d -s "$sess" \
        "printf '\033[48;2;${rgb}m'; clear; sleep 30"

    tmux display-popup "${popup_args[@]}" \
        -E "tmux attach -t '$sess'" &
    POPUP_PID=$!
    sleep 0.3
}

popup_fill_check() {
    local rgb="$1" label="$2"
    local capture
    capture=$(tmux capture-pane -t "_tpr" -e -p 2>/dev/null)
    local total_lines styled_lines
    total_lines=$(echo "$capture" | wc -l)
    styled_lines=$(echo "$capture" | grep -c "48;2;${rgb}" 2>/dev/null) || styled_lines=0
    assert_eq "$label" "$total_lines" "$styled_lines"
}


# ════════════════════════════════════════════════════════════════
# Tests
# ════════════════════════════════════════════════════════════════

section "Popup pane dimensions: standalone (-E)"

result=$(popup_tty_size -w "$small_w" -h "$small_h" -b none)
assert_eq "standalone-small" "${small_w}x${small_h}" "$result"

result=$(popup_tty_size -w "$med_w" -h "$med_h" -b none)
assert_eq "standalone-med" "${med_w}x${med_h}" "$result"

section "Popup pane dimensions: bordered"

expect_pw=$(( small_w - 2 ))
expect_ph=$(( small_h - 2 ))
result=$(popup_tty_size -w "$small_w" -h "$small_h" -b rounded)
assert_eq "bordered-small" "${expect_pw}x${expect_ph}" "$result"

section "Popup pane dimensions: sequential sizes"

popup_tty_size -w "$small_w" -h "$small_h" -b none > /dev/null
result=$(popup_tty_size -w "$med_w" -h "$med_h" -b none)
assert_eq "seq-small-to-med" "${med_w}x${med_h}" "$result"

popup_tty_size -w "$med_w" -h "$med_h" -b none > /dev/null
result=$(popup_tty_size -w "$small_w" -h "$small_h" -b none)
assert_eq "seq-med-to-small" "${small_w}x${small_h}" "$result"

section "Popup session dimensions"

popup_session_open -w "$med_w" -h "$med_h" -b none
result=$(popup_session_query '#{pane_width}x#{pane_height}')
expect_sh=$(( med_h - 1 ))  # session status bar
assert_eq "session-med" "${med_w}x${expect_sh}" "$result"
popup_session_close

section "Style fill: -s bg= (session capture)"

popup_session_open -w "$small_w" -h "$small_h" -b none -s "bg=red"
capture=$(popup_session_capture)
popup_session_close
line_count=$(echo "$capture" | wc -l)
styled_count=$(echo "$capture" | grep -c $'\033' 2>/dev/null) || styled_count=0
assert_eq "bg-fill-styled" "$line_count" "$styled_count"

section "Style fill: -s bg= with clear"

popup_session_open -w "$small_w" -h "$small_h" -b none -s "bg=red"
capture=$(popup_session_capture "clear")
popup_session_close
line_count=$(echo "$capture" | wc -l)
styled_count=$(echo "$capture" | grep -c $'\033' 2>/dev/null) || styled_count=0
assert_eq "bg-clear-styled" "$line_count" "$styled_count"

section "Style fill: ANSI escape bg + clear"

popup_session_open -w "$small_w" -h "$small_h" -b none
capture=$(popup_session_capture "printf '\\033[41m'; clear")
popup_session_close
line_count=$(echo "$capture" | wc -l)
styled_count=$(echo "$capture" | grep -c $'\033' 2>/dev/null) || styled_count=0
assert_eq "ansi-clear-styled" "$line_count" "$styled_count"

# ── animated expand sequence ───────────────────────────────────

section "Animation: expand dimensions (standalone)"

anim_old_w=$small_w anim_old_h=$small_h
anim_new_w=$large_w anim_new_h=$large_h
anim_frames=4

for (( f = 1; f <= anim_frames; f++ )); do
    (( progress = f * 1000 / anim_frames )) || true
    eased=$(pg_ease "$progress" ease-in-out)
    (( w = anim_old_w + (anim_new_w - anim_old_w) * eased / 1000 )) || true
    (( h = anim_old_h + (anim_new_h - anim_old_h) * eased / 1000 )) || true
    if (( w < 3 )); then w=3; fi
    if (( h < 1 )); then h=1; fi

    result=$(popup_tty_size -w "$w" -h "$h" -b none)
    assert_eq "expand-f${f}-size" "${w}x${h}" "$result"
done

section "Animation: expand dimensions (rapid sequence)"

for (( f = 1; f <= anim_frames; f++ )); do
    (( progress = f * 1000 / anim_frames )) || true
    eased=$(pg_ease "$progress" ease-in-out)
    (( w = anim_old_w + (anim_new_w - anim_old_w) * eased / 1000 )) || true
    (( h = anim_old_h + (anim_new_h - anim_old_h) * eased / 1000 )) || true
    if (( w < 3 )); then w=3; fi
    if (( h < 1 )); then h=1; fi

    tmux display-popup -w "$w" -h "$h" -b none -E true 2>/dev/null || true
done

result=$(popup_tty_size -w "$anim_new_w" -h "$anim_new_h" -b none)
assert_eq "rapid-final-size" "${anim_new_w}x${anim_new_h}" "$result"

section "Animation: expand fill (session per frame)"

test_rgb="205;100;100"
for (( f = 1; f <= anim_frames; f++ )); do
    (( progress = f * 1000 / anim_frames )) || true
    eased=$(pg_ease "$progress" ease-in-out)
    (( w = anim_old_w + (anim_new_w - anim_old_w) * eased / 1000 )) || true
    (( h = anim_old_h + (anim_new_h - anim_old_h) * eased / 1000 )) || true
    if (( w < 3 )); then w=3; fi
    if (( h < 1 )); then h=1; fi

    popup_fill_open -w "$w" -h "$h" -b none "$test_rgb"
    popup_fill_check "$test_rgb" "expand-f${f}-fill"
    popup_session_close
done

section "Animation: shrink dimensions (standalone)"

for (( f = 1; f <= anim_frames; f++ )); do
    (( progress = f * 1000 / anim_frames )) || true
    eased=$(pg_ease "$progress" ease-in-out)
    (( w = anim_new_w + (anim_old_w - anim_new_w) * eased / 1000 )) || true
    (( h = anim_new_h + (anim_old_h - anim_new_h) * eased / 1000 )) || true
    if (( w < 3 )); then w=3; fi
    if (( h < 1 )); then h=1; fi

    result=$(popup_tty_size -w "$w" -h "$h" -b none)
    assert_eq "shrink-f${f}-size" "${w}x${h}" "$result"
done

section "Animation: rapid expand then verify fill"

for (( f = 1; f <= anim_frames; f++ )); do
    (( progress = f * 1000 / anim_frames )) || true
    eased=$(pg_ease "$progress" ease-in-out)
    (( w = anim_old_w + (anim_new_w - anim_old_w) * eased / 1000 )) || true
    (( h = anim_old_h + (anim_new_h - anim_old_h) * eased / 1000 )) || true
    if (( w < 3 )); then w=3; fi
    if (( h < 1 )); then h=1; fi

    tmux display-popup -w "$w" -h "$h" -b none -s "bg=red" \
        -E clear 2>/dev/null || true
done

popup_fill_open -w "$anim_new_w" -h "$anim_new_h" -b none "$test_rgb"
popup_fill_check "$test_rgb" "post-rapid-fill"
popup_session_close

result=$(popup_tty_size -w "$anim_new_w" -h "$anim_new_h" -b none)
assert_eq "post-rapid-dims" "${anim_new_w}x${anim_new_h}" "$result"

section "Animation: standalone fill (popup-resize approach)"

for (( f = 1; f <= anim_frames; f++ )); do
    (( progress = f * 1000 / anim_frames )) || true
    eased=$(pg_ease "$progress" ease-in-out)
    (( w = anim_old_w + (anim_new_w - anim_old_w) * eased / 1000 )) || true
    (( h = anim_old_h + (anim_new_h - anim_old_h) * eased / 1000 )) || true
    if (( w < 3 )); then w=3; fi
    if (( h < 1 )); then h=1; fi

    local_out="$tmpdir/standalone-f${f}.txt"
    tmux display-popup -x C -y C -w "$w" -h "$h" \
        -b none -E "stty size > '$local_out'; clear" 2>/dev/null || true

    if [[ -f "$local_out" ]]; then
        read -r rows cols < "$local_out"
        assert_eq "standalone-expand-f${f}" "${w}x${h}" "${cols}x${rows}"
        rm -f "$local_out"
    else
        (( total++ )); (( fail++ ))
        printf "  \033[31mFAIL\033[0m  standalone-expand-f${f}: popup failed to open\n"
    fi
done

section "Animation fill: session-based color assertion"

test_fg="#cdd6f4"
test_rgb=$(hex_to_rgb "$test_fg")

for (( f = 1; f <= anim_frames; f++ )); do
    (( progress = f * 1000 / anim_frames )) || true
    eased=$(pg_ease "$progress" ease-in-out)
    (( w = anim_old_w + (anim_new_w - anim_old_w) * eased / 1000 )) || true
    (( h = anim_old_h + (anim_new_h - anim_old_h) * eased / 1000 )) || true
    if (( w < 3 )); then w=3; fi
    if (( h < 1 )); then h=1; fi

    popup_fill_open -w "$w" -h "$h" -x C -y C -b none "$test_rgb"
    popup_fill_check "$test_rgb" "anim-fill-f${f}-${w}x${h}"
    popup_session_close
done

section "Style mechanism: -s bg= vs ANSI escape"

sess_a="_tpr"

tmux kill-session -t "$sess_a" 2>/dev/null || true
tmux new-session -d -s "$sess_a" -x "$small_w" -y "$small_h" "clear; sleep 10"
tmux display-popup -w "$small_w" -h "$small_h" -b none -s "bg=#cdd6f4" \
    -E "tmux attach -t '$sess_a'" &
local_pid=$!; sleep 0.3
capture_a=$(tmux capture-pane -t "$sess_a" -e -p 2>/dev/null)
tmux kill-session -t "$sess_a" 2>/dev/null; wait "$local_pid" 2>/dev/null || true
styled_a=$(echo "$capture_a" | grep -c "48;2" 2>/dev/null) || styled_a=0
assert_eq "s-style-no-ansi-bg" "0" "$styled_a"

tmux kill-session -t "$sess_a" 2>/dev/null || true
tmux new-session -d -s "$sess_a" -x "$small_w" -y "$small_h" \
    "printf '\033[48;2;${test_rgb}m'; clear; sleep 10"
tmux display-popup -w "$small_w" -h "$small_h" -b none \
    -E "tmux attach -t '$sess_a'" &
local_pid=$!; sleep 0.3
capture_b=$(tmux capture-pane -t "$sess_a" -e -p 2>/dev/null)
tmux kill-session -t "$sess_a" 2>/dev/null; wait "$local_pid" 2>/dev/null || true
styled_b=$(echo "$capture_b" | grep -c "48;2;${test_rgb}" 2>/dev/null) || styled_b=0
total_b=$(echo "$capture_b" | wc -l)
assert_eq "ansi-escape-has-bg" "$total_b" "$styled_b"


# ── summary ────────────────────────────────────────────────────

printf "\n\033[1m%d tests: %d passed, %d failed\033[0m\n" "$total" "$pass" "$fail"
(( fail == 0 )) || exit 1
