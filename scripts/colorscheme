    C0="#15161e"  C1="#f7768e"  C2="#9ece6a"  C3="#e0af68"
    C4="#7aa2f7"  C5="#bb9af7"  C6="#7dcfff"  C7="#a9b1d6"
    C8="#414868"  C9="#f7768e"  C10="#9ece6a" C11="#e0af68"
