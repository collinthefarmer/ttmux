#!/usr/bin/env bash
#
# colorscheme — generate, save, and apply terminal color schemes via tmux
#
# Usage:
#   colorscheme generate <session-name>   Print the full palette as shell variables
#   colorscheme apply <session-name>       Apply scheme to session (terminal + tmux chrome)
#   colorscheme apply-current              Apply scheme for the current session (used by hooks)
#   colorscheme save <session-name>        Write scheme to ~/.local/share/ttmux/schemes/<name>.conf
#   colorscheme preview                    Cycle through all schemes on the current session
#   colorscheme hook-init <ttmux-dir>      Install the client-session-changed hook
#
# Changes the terminal itself — the 16 ANSI colors, default foreground,
# background, and cursor — via OSC escape sequences pushed through tmux
# passthrough. Also styles tmux status bar, pane borders, and mode colors
# to match. A session-switch hook re-applies the palette whenever you move
# between sessions, so each project keeps its own color identity.

set -euo pipefail

SCHEME_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/ttmux/schemes"

# --- palette definitions ------------------------------------------------
#
# Each scheme defines:
#   BG, FG, CURSOR    — terminal default background, foreground, cursor
#   C0..C15           — the 16 ANSI palette colors
#   STATUS_BG/FG      — tmux status bar
#   STATUS_ACTIVE_BG/FG — active window tab
#   PANE_BORDER/ACTIVE — pane border colors
#   MSG_BG/FG         — tmux messages
#   MODE_BG/FG        — copy mode highlight

declare -a SCHEME_NAMES=(
    dracula
    solarized
    gruvbox
    nord
    monokai
    rosepine
    catppuccin
    kanagawa
    everforest
    tokyonight
)

scheme_dracula() {
    BG="#282a36"  FG="#f8f8f2"  CURSOR="#f8f8f2"
    C0="#21222c"  C1="#ff5555"  C2="#50fa7b"  C3="#f1fa8c"
    C4="#bd93f9"  C5="#ff79c6"  C6="#8be9fd"  C7="#f8f8f2"
    C8="#6272a4"  C9="#ff6e6e"  C10="#69ff94" C11="#ffffa5"
    C12="#d6acff" C13="#ff92df" C14="#a4ffff" C15="#ffffff"
    STATUS_BG="#44475a"  STATUS_FG="#f8f8f2"
    STATUS_ACTIVE_BG="#bd93f9"  STATUS_ACTIVE_FG="#282a36"
    PANE_BORDER="#44475a"  PANE_ACTIVE="#bd93f9"
    MSG_BG="#44475a"  MSG_FG="#f8f8f2"
    MODE_BG="#44475a"  MODE_FG="#f8f8f2"
}

