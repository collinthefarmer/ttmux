#!/usr/bin/env bash
#
# agent-popup — open the agent popup with key restriction
#
# Ensures the agent session exists, applies popup key restrictions,
# opens the popup, and restores key state on close.
#
# Reads from tmux session options:
#   @agentSessionName    — the agent session name (e.g. agent@projects/foo)
#   @commandAgentSession — the tmux new-session command for display-popup
#   @cmdAgent            — the agent command (server option)
#
# Usage:
#   agent-popup <ttmux-dir>

set -euo pipefail

dir="${1:?usage: agent-popup <ttmux-dir>}"
popup_keys="$dir/scripts/popup-keys"

session=$(tmux show-option -qv @agentSessionName)
attach_cmd=$(tmux show-option -qv @commandAgentSession)
agent_cmd=$(tmux show-option -sqv @cmdAgent)

[[ -n "$session" ]] || { echo "agent-popup: @agentSessionName not set" >&2; exit 1; }

# ensure agent session exists
tmux has-session -t "$session" 2>/dev/null \
    || tmux new-session -d -s "$session" "$agent_cmd"

# restrict keybinds, open popup, restore on close
"$popup_keys" open agent "$session"
tmux display-popup -b rounded -w 80 -h 75% -E "$attach_cmd"
"$popup_keys" close "$session"
